# ── Jira Configuration ──────────────────────────────────────────
# Option A: Use a secrets.toml file (see secrets.toml.example)
# Option B: Set these env vars (takes effect only if secrets.toml is absent)

# Server type: "cloud" or "server"
JIRA_SERVER_TYPE=server
JIRA_BASE_URL=http://localhost:8080
JIRA_PROJECT_KEY=MTE
JIRA_ISSUE_TYPE=10005

# Auth for Jira Cloud (email + API token)
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-api-token

# Auth for Jira Server / Data Center (username + password)
JIRA_USERNAME=admin
JIRA_PASSWORD=admin

# ── App Configuration ───────────────────────────────────────────
APP_PORT=8501
