# Copy this file to secrets.toml and fill in your Jira credentials.
# The app works fully without Jira — leave unconfigured to skip integration.
#
# Supports both Jira Cloud and Jira Server/Data Center.

[jira]

# ── Server Type ─────────────────────────────────────────────────
# "cloud"  = Jira Cloud (atlassian.net) — uses email + API token
# "server" = Jira Server / Data Center  — uses username + password
server_type = "server"

# ── Connection ──────────────────────────────────────────────────
# Cloud:  https://your-org.atlassian.net
# Server: http://localhost:8080
base_url    = "http://localhost:8080"

# ── Auth: Jira Cloud ────────────────────────────────────────────
# email       = "you@example.com"
# api_token   = "your-api-token"

# ── Auth: Jira Server / Data Center ─────────────────────────────
username    = "admin"
password    = "admin"

# ── Project ─────────────────────────────────────────────────────
project_key = "MTE"
issue_type  = "10005"
